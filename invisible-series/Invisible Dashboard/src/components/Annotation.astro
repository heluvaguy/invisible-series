---
interface Props {
  label?: string;
}
const { label = 'Note' } = Astro.props;
---
<aside class="annotation">
  <span class="annotation-label">{label} —</span>
  <slot />
</aside>

<style>
  .annotation {
    background: var(--terra-50);
    border: 0.5px solid var(--terra-100);
    border-radius: var(--radius-md);
    padding: var(--sp-3) var(--sp-4);
    margin: var(--sp-6) 0;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--terra-800);
  }

  .annotation-label {
    font-weight: 500;
    margin-right: 0.25em;
  }

  .annotation :global(p) {
    display: inline;
    margin: 0;
  }
</style>
